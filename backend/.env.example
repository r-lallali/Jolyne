# Environnement
JOLYNE_ENV=dev               # dev | prod
JOLYNE_PORT=8080

# Redis
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0

# Postgres (Phase 2+). Si vide, le gateway démarre sans Postgres et les
# features qui en dépendent (signalements, bans persistants) sont désactivées.
POSTGRES_DSN=postgres://jolyne:jolyne@127.0.0.1:5432/jolyne?sslmode=disable
# Si true, lance `migrate up` au boot (idempotent). Utile en dev/CI.
# En prod, préférer `false` et lancer les migrations explicitement.
POSTGRES_AUTO_MIGRATE=true

# Shutdown
SHUTDOWN_GRACE=30s

# Phase 2 — signalements. Clé AES-256 base64 (32 octets) pour chiffrer les
# messages capturés lors d'un signalement. Génération :
#   openssl rand -base64 32
# Sans cette clé, le bouton "Signaler" renvoie une erreur applicative.
REPORT_ENCRYPTION_KEY=

# Back-office admin (Phase 2). Sans ces variables, /api/admin/* renvoie 404.
#
# ADMIN_USERS : liste email:bcrypt_hash séparée par `;`. Pour générer un hash :
#   python3 -c "import bcrypt; print(bcrypt.hashpw(b'monpass', bcrypt.gensalt(10)).decode())"
ADMIN_USERS=
# CSV d'IP ou de CIDR autorisées. Vide = pas de filtrage (à éviter en prod).
ADMIN_IP_ALLOWLIST=
# Clé HMAC base64 (≥ 32 octets). openssl rand -base64 48
ADMIN_SESSION_SECRET=
# Domaine du cookie. ex: ralys.ovh (partagé entre jolyne.* et api.jolyne.*)
ADMIN_COOKIE_DOMAIN=
# Origin frontend autorisée à appeler /api/admin/*. ex: https://jolyne.ralys.ovh
ADMIN_CORS_ORIGIN=

# --- Bot prof IA (Anthropic Claude). ---
# Sans ANTHROPIC_API_KEY, le bot est DÉSACTIVÉ : le mode "Prof IA" ne se lance
# pas et aucun bot de repli n'apparaît après le délai d'attente. Clé sur
# https://console.anthropic.com → API Keys.
ANTHROPIC_API_KEY=
# ID de modèle CANONIQUE (avec date). Laisser vide = default code
# (claude-haiku-4-5-20251001). Ne pas mettre un modèle inconnu : tout appel
# échoue alors en 404 et le prof IA reste muet (réponses de repli uniquement).
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# Nb max de conversations bot simultanées, et délai (s) avant qu'un bot prenne
# le relais quand aucun partenaire humain n'arrive.
BOT_MAX_CONCURRENT=20
BOT_TRIGGER_DELAY_SEC=10

# --- Premium (Stripe). Billing actif si SECRET_KEY + PRICE_ID présents. ---
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID=price_...        # abonnement Premium (mode subscription)
# STRIPE_SUCCESS_URL=              # défaut: ${PUBLIC_APP_URL}/premium/success
# STRIPE_CANCEL_URL=               # défaut: ${PUBLIC_APP_URL}/premium/cancel

# --- Phase 3+ (encore non utilisés) ---
# MAGIC_LINK_SIGNING_KEY=
