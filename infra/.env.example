# Variables consommées par docker-compose.yml (prod sur VPS)

# Domaine HTTPS — Caddy obtient un certificat Let's Encrypt automatiquement
JOLYNE_DOMAIN=jolyne.ralys.ovh

# Redis (laisse vide en MVP, à durcir avant ouverture publique)
REDIS_PASSWORD=

# Reverse-proxies de confiance en frontal (Caddy = 1). Sert à résoudre l'IP
# cliente réelle depuis X-Forwarded-For sans se faire usurper. Défaut = 1 ;
# mettre 0 seulement si le backend est exposé en direct (sans proxy).
# TRUSTED_PROXY_COUNT=1

# --- Phase 2+ (encore non utilisés côté infra) ---
# POSTGRES_USER=jolyne
# POSTGRES_PASSWORD=
# POSTGRES_DB=jolyne
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
